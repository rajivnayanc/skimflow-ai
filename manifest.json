{
    "manifest_version": 3,
    "name": "Faster Reading - AI Powered RSVP",
    "version": "1.0",
    "description": "Read faster with RSVP, AI summarization, and smart formatting.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ]
}